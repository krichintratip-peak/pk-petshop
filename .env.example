# Copy to .env and adjust (dev). Never commit real secrets.

# Optional in dev; defaults to insecure dev key if unset
# DJANGO_SECRET_KEY=

# Optional: extra hosts (comma-separated). Dev always allows localhost / 127.0.0.1
# DJANGO_ALLOWED_HOSTS=

# --- Production (mysite.settings.prod) ---
# DJANGO_SECRET_KEY=required
# DJANGO_ALLOWED_HOSTS=example.com,www.example.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
# DJANGO_USE_TLS=1

# --- Docker: Postgres + Adminer + Web (see docker.env.example -> docker.env) ---
# docker compose --profile prod up --build
# docker compose --profile dev up --build
# Adminer http://127.0.0.1:8080  (Server: db)
