# Copy to docker.env (do not commit docker.env).
# Used by docker compose for Django (web / web-dev).

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web

# PostgreSQL — ต้องตรงกับ service `db` ใน docker-compose.yml (ค่าเริ่มต้น petshop / petshop)
# เปลี่ยนรหัสผ่านจริงใน production
POSTGRES_DB=petshop
POSTGRES_USER=petshop
POSTGRES_PASSWORD=petshop

# ถ้ารัน Django กับ Postgres นอก Docker: pip install psycopg2-binary

# Optional behind HTTPS reverse proxy:
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com
# DJANGO_USE_TLS=1
